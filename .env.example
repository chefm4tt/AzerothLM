# -----------------------------------------------------------------------------
# Configuration
# -----------------------------------------------------------------------------
# Path to your WoW SavedVariables file. Update 'YOUR_ACCOUNT_NAME' to match your folder.
WOW_SAVED_VARIABLES_PATH=C:\Program Files (x86)\World of Warcraft\_anniversary_\WTF\Account\YOUR_ACCOUNT_NAME\SavedVariables\AzerothLM.lua

# Path to the AzerothLM addon folder. The relay writes AzerothLM_Signal.lua here.
WOW_ADDON_PATH=C:\Program Files (x86)\World of Warcraft\_anniversary_\Interface\AddOns\AzerothLM

# -----------------------------------------------------------------------------
# API Keys
# API keys can also be added interactively with the /model add command.
# -----------------------------------------------------------------------------
# Google Gemini API Key
# Required: Get your free API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=YOUR_API_KEY_HERE

# OpenAI API Key (Optional)
# Required only if using GPT models: https://platform.openai.com/api-keys
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# Anthropic API Key (Optional)
# Required only if using Claude models: https://console.anthropic.com/
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# -----------------------------------------------------------------------------
# AI Model Selection
# -----------------------------------------------------------------------------
# Uncomment the MODEL_NAME you wish to use.
# The relay uses 'litellm', so many providers are supported.

# --- Google Gemini ---
# gemini/gemini-2.5-flash: Extremely fast, low latency (Recommended).
# gemini/gemini-2.5-pro: High reasoning capability, larger context window.
# MODEL_NAME=gemini/gemini-2.5-flash
# MODEL_NAME=gemini/gemini-2.5-pro

# --- OpenAI ---
# openai/gpt-4o: Current flagship model.
# openai/gpt-4o-mini: Fast and cost-efficient.
# openai/o3-mini: Advanced reasoning model.
# MODEL_NAME=openai/gpt-4o
# MODEL_NAME=openai/gpt-4o-mini
# MODEL_NAME=openai/o3-mini

# --- Anthropic ---
# anthropic/claude-sonnet-4-20250514: Excellent reasoning and coding abilities.
# anthropic/claude-haiku-4-5-20251001: Fast and cost-efficient Claude model.
# MODEL_NAME=anthropic/claude-sonnet-4-20250514
# MODEL_NAME=anthropic/claude-haiku-4-5-20251001

# --- Local / Ollama ---
# MODEL_NAME=ollama/llama3

# Active Model (Default)
MODEL_NAME=gemini/gemini-2.5-flash

# -----------------------------------------------------------------------------
# Development & Diagnostics
# -----------------------------------------------------------------------------
# Set to true to test the relay and UI without using API credits.
# Can also be toggled at runtime with the /test on and /test off commands.
TESTING_MODE=false

# Set to true to enable verbose diagnostic output on startup (stderr).
# Equivalent to passing --debug on the command line.
# Useful when running the relay as a standalone MCP server or in a background process.
DEBUG=false